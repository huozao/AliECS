# 复制此文件为 deploy/ecs/release-meta.env 后再改值
APP_ROOT=/opt/app
COMPOSE_FILE=/opt/app/deploy/ecs/compose.prod.yml
RUNTIME_ENV_FILE=/opt/app/deploy/ecs/runtime.env
METADATA_DIR=/opt/app/deploy/ecs/.release-meta
MIGRATIONS_DIR=/opt/app/db/migrations
HEALTHCHECK_URL=http://127.0.0.1:8000/readyz
HEALTHCHECK_RETRIES=20
HEALTHCHECK_INTERVAL_SECONDS=3
DEPLOY_LOG_DIR=/opt/app/deploy/ecs/logs

# GHCR 命名空间：ghcr.io/<GitHub 用户或组织>
GHCR_BASE=ghcr.io/huozao

# GHCR 私有镜像推荐配置：填写 GHCR_USERNAME + GHCR_TOKEN(PAT: read:packages)
GHCR_USERNAME=
GHCR_TOKEN=

# 数据库运行配置
POSTGRES_USER=app
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=app
DATABASE_URL=postgresql://app:replace_with_strong_password@postgres:5432/app
