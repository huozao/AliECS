# 复制此文件为 /opt/app/deploy/ecs/release-meta.env 后再改值
# 注意：release-meta.env 是服务器私有配置，真实文件不要提交到 GitHub。

APP_ROOT=/opt/app
COMPOSE_FILE=/opt/app/deploy/ecs/compose.prod.yml
RUNTIME_ENV_FILE=/opt/app/deploy/ecs/runtime.env
METADATA_DIR=/opt/app/deploy/ecs/.release-meta
MIGRATIONS_DIR=/opt/app/db/migrations

HEALTHCHECK_URL=http://127.0.0.1:8000/readyz
HEALTHCHECK_RETRIES=20
HEALTHCHECK_INTERVAL_SECONDS=3
DEPLOY_LOG_DIR=/opt/app/deploy/ecs/logs

GHCR_BASE=ghcr.io/huozao

# 如果 GHCR 镜像是 private，需要配置 GitHub PAT，权限至少 read:packages。
GHCR_USERNAME=
GHCR_TOKEN=

POSTGRES_USER=app
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=app
DATABASE_URL=postgresql://app:replace_with_strong_password@postgres:5432/app

# 用 openssl rand -hex 32 生成。
AUTH_TOKEN_SECRET=replace_with_secure_random_secret
AUTH_TOKEN_TTL_SECONDS=28800

# 首次 users 表为空时，后端会创建这个管理员。
# 如果 users 表已经有用户，这些变量不会覆盖已有密码。
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace_with_secure_password
ADMIN_BOOTSTRAP_DISPLAY_NAME=系统管理员